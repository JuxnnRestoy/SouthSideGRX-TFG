<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardCornerRadius="10dp"
    app:cardUseCompatPadding="true">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:orientation="vertical">

        <!-- Información del producto -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Imagen del producto -->
            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:id="@+id/imagenProdCar"
                android:src="@drawable/ico_producto"
                android:layout_marginTop="2dp"
                android:scaleType="centerCrop"/>

            <!-- Nombre del producto -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/nombrePCar"
                android:text="@string/nombre_p_car"
                android:layout_toEndOf="@id/imagenProdCar"
                android:layout_marginStart="10dp"
                android:textColor="@color/azul_marino_oscuro"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <!-- Precio final -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/precioFinalPCar"
                android:text="@string/precio_final_p_car"
                android:layout_below="@+id/nombrePCar"
                android:layout_toEndOf="@id/imagenProdCar"
                android:layout_marginStart="10dp"
                android:textSize="17sp"/>

            <!-- Precio original -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/precio_original_p_car"
                android:id="@+id/precioOriginalPCar"
                android:layout_below="@id/precioFinalPCar"
                android:layout_toEndOf="@id/imagenProdCar"
                android:layout_marginStart="10dp"
                android:textSize="17sp"/>

        </RelativeLayout>

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="bottom"
            android:gravity="center_horizontal"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="5dp">

            <EditText
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/edtCantidadProductosCar"
                android:text="@string/cantidad_p_car"
                android:textSize="18sp"/>
            
            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/btnEliminarCarrito"
                android:src="@drawable/ico_borrar_"
                android:background="@null"
                android:layout_marginStart="100dp"/>

        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.appcompat.widget.LinearLayoutCompat>

</com.google.android.material.card.MaterialCardView>